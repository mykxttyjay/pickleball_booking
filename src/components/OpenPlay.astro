---
---

<div id="open-play" class="tab-section bg-white rounded-lg shadow-xl p-8 hidden">
  <h2 class="text-3xl font-bold text-gray-800 mb-6 pb-4 border-b-4 border-blue-500">Open Play Sessions</h2>
  
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Schedule Form -->
    <div class="bg-gray-50 border-l-4 border-blue-500 p-6 rounded-lg lg:col-span-1">
      <h3 class="text-xl font-bold text-gray-800 mb-4">Schedule Open Play</h3>
      <form class="space-y-3" onsubmit="handleSession(event)">
        <div>
          <label class="block text-gray-700 font-semibold mb-2 text-sm">Court *</label>
          <select required class="w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500 text-sm">
            <option value="">Select court...</option>
            <option value="court-a">Court A</option>
            <option value="court-b">Court B</option>
            <option value="court-c">Court C</option>
          </select>
        </div>

        <div>
          <label class="block text-gray-700 font-semibold mb-2 text-sm">Date *</label>
          <input type="date" required class="w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500 text-sm" />
        </div>

        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="block text-gray-700 font-semibold mb-1 text-sm">Start *</label>
            <input type="time" required class="w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500 text-sm" />
          </div>
          <div>
            <label class="block text-gray-700 font-semibold mb-1 text-sm">End *</label>
            <input type="time" required class="w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500 text-sm" />
          </div>
        </div>

        <div>
          <label class="block text-gray-700 font-semibold mb-2 text-sm">Skill Level</label>
          <select class="w-full px-3 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500 text-sm">
            <option value="all">All Levels</option>
            <option value="beginner">Beginner</option>
            <option value="intermediate">Intermediate</option>
            <option value="advanced">Advanced</option>
          </select>
        </div>

        <button type="submit" class="w-full bg-blue-500 text-white py-3 px-4 rounded-lg font-bold hover:bg-blue-600 transition-colors text-sm">
          Schedule Session
        </button>
      </form>
    </div>

    <!-- Sessions Grid -->
    <div class="lg:col-span-2">
      <h3 class="text-2xl font-bold text-gray-800 mb-4">Upcoming Sessions</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="border-2 border-gray-200 rounded-lg p-4 bg-white hover:border-blue-300 transition-all cursor-pointer">
          <h4 class="font-bold text-gray-800">🎾 2024-07-25</h4>
          <p class="text-sm text-gray-600 mt-1">09:00 - 11:00</p>
          <p class="text-sm text-gray-600"><strong>Court:</strong> Court A</p>
          <p class="text-sm text-gray-600"><strong>Level:</strong> All Levels</p>
          <div class="mt-3 flex items-center justify-between">
            <span class="text-sm font-semibold text-blue-600">2/4 players</span>
            <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-semibold">scheduled</span>
          </div>
          <button class="w-full mt-3 bg-green-500 text-white py-2 px-4 rounded-lg hover:bg-green-600 transition-colors text-sm font-semibold">
            Join Session
          </button>
        </div>

        <div class="border-2 border-gray-200 rounded-lg p-4 bg-white hover:border-blue-300 transition-all cursor-pointer">
          <h4 class="font-bold text-gray-800">🎾 2024-07-26</h4>
          <p class="text-sm text-gray-600 mt-1">16:00 - 18:00</p>
          <p class="text-sm text-gray-600"><strong>Court:</strong> Court B</p>
          <p class="text-sm text-gray-600"><strong>Level:</strong> Intermediate</p>
          <div class="mt-3 flex items-center justify-between">
            <span class="text-sm font-semibold text-blue-600">3/4 players</span>
            <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-semibold">scheduled</span>
          </div>
          <button class="w-full mt-3 bg-green-500 text-white py-2 px-4 rounded-lg hover:bg-green-600 transition-colors text-sm font-semibold">
            Join Session
          </button>
        </div>

        <div class="border-2 border-gray-200 rounded-lg p-4 bg-white hover:border-blue-300 transition-all cursor-pointer">
          <h4 class="font-bold text-gray-800">🎾 2024-07-27</h4>
          <p class="text-sm text-gray-600 mt-1">10:00 - 12:00</p>
          <p class="text-sm text-gray-600"><strong>Court:</strong> Court C</p>
          <p class="text-sm text-gray-600"><strong>Level:</strong> Beginner</p>
          <div class="mt-3 flex items-center justify-between">
            <span class="text-sm font-semibold text-blue-600">1/4 players</span>
            <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs font-semibold">scheduled</span>
          </div>
          <button class="w-full mt-3 bg-green-500 text-white py-2 px-4 rounded-lg hover:bg-green-600 transition-colors text-sm font-semibold">
            Join Session
          </button>
        </div>

        <div class="border-2 border-gray-200 rounded-lg p-4 bg-white hover:border-blue-300 transition-all cursor-pointer">
          <h4 class="font-bold text-gray-800">🎾 2024-07-28</h4>
          <p class="text-sm text-gray-600 mt-1">14:00 - 16:00</p>
          <p class="text-sm text-gray-600"><strong>Court:</strong> Court A</p>
          <p class="text-sm text-gray-600"><strong>Level:</strong> Advanced</p>
          <div class="mt-3 flex items-center justify-between">
            <span class="text-sm font-semibold text-blue-600">4/4 players</span>
            <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs font-semibold">full</span>
          </div>
          <button class="w-full mt-3 bg-gray-400 text-white py-2 px-4 rounded-lg cursor-not-allowed text-sm font-semibold">
            Full
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function handleSession(e) {
    e.preventDefault();
    alert('Session scheduled! This is a demo.');
  }
</script>
