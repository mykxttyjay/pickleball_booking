---
---

<!-- Top Banner -->
<div class="bg-gradient-to-r from-[#143315] to-[#1a4a1f] text-white py-3 fixed w-full top-0 z-50 border-b border-[#efe7dc]/20">
  <div class="header-padding" style="padding-left: 100px; padding-right: 100px;">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2 text-xs sm:text-sm">
      <div class="flex items-center gap-3">
        <span class="flex items-center gap-2 font-semibold">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
          </svg>
          We're Open 24 Hours
        </span>
        <span class="hidden sm:inline text-white/30">|</span>
        <span class="flex items-center gap-2 text-white/90">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          Join Open Play Now!
        </span>
      </div>
      <a href="tel:0966576931" class="flex items-center gap-2 font-semibold hover:text-[#efe7dc] transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
        <span>0966 576 931 / 0916 460 1708</span>
      </a>
    </div>
  </div>
</div>

<!-- Header -->
<header class="bg-white shadow-lg fixed w-full top-[42px] z-40">
  <div class="w-full py-3 md:py-4 flex items-center justify-between header-padding" style="padding-left: 100px; padding-right: 100px;">
    <div class="flex items-center gap-4 md:gap-8">
      <div class="flex items-center gap-3">
        <img src="/casaruginalogo.jpg" alt="Casa Rugina Logo" class="h-8 md:h-12 w-auto object-contain" />
        <div class="hidden sm:block text-[#143315]">
          <h1 class="font-bold text-sm md:text-base lg:text-lg leading-tight">Casa Rugina Pickleball Club</h1>
          <p class="text-[10px] md:text-xs uppercase tracking-wider text-[#143315]/70">Play. Connect. Belong.</p>
        </div>
      </div>
    </div>
    <div class="hidden lg:block">
      <a href="#booking" class="inline-flex items-center gap-2 bg-[#143315] text-white font-bold py-2.5 px-6 rounded-lg hover:bg-[#1a4a1f] transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
        Book Now
      </a>
    </div>
    <!-- Mobile menu button -->
    <button class="md:hidden text-[#143315]" id="mobile-menu-btn" aria-label="Toggle menu">
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
  <!-- Mobile menu -->
  <div class="hidden md:hidden bg-white border-t" id="mobile-menu">
    <nav class="flex flex-col px-4 py-4 space-y-2">
      <a href="#home" class="mobile-link text-[#143315] font-medium py-2 hover:bg-[#efe7dc] px-2 rounded">Home</a>
      <a href="#gallery" class="mobile-link text-[#143315] font-medium py-2 hover:bg-[#efe7dc] px-2 rounded">Gallery</a>
      <a href="#booking" class="mobile-link text-[#143315] font-medium py-2 hover:bg-[#efe7dc] px-2 rounded">Book</a>
      <a href="tel:0966576931" class="text-[#143315] font-medium py-2 hover:bg-[#efe7dc] px-2 rounded flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
        </svg>
        Call us
      </a>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Close mobile menu when clicking a link
    document.querySelectorAll('.mobile-link').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });
  }
</script>
