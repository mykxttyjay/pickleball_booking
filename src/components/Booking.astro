---

<div id="booking" class="tab-section bg-white rounded-lg shadow-xl p-8 mb-8 hidden">
  <h2 class="text-3xl font-bold text-gray-800 mb-6 pb-4 border-b-4 border-blue-500">Book a Court</h2>
  
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    <!-- Booking Form -->
    <div>
      <form class="space-y-4" onsubmit="handleBooking(event)">
        <div>
          <label class="block text-gray-700 font-semibold mb-2">Select Court *</label>
          <select required class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500">
            <option value="">Choose a court...</option>
            <option value="court-a">Court A - Downtown Park</option>
            <option value="court-b">Court B - Central Recreation</option>
            <option value="court-c">Court C - Riverside Complex</option>
          </select>
        </div>

        <div>
          <label class="block text-gray-700 font-semibold mb-2">Date *</label>
          <input type="date" required class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500" />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-gray-700 font-semibold mb-2">Start Time *</label>
            <input type="time" required class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500" />
          </div>
          <div>
            <label class="block text-gray-700 font-semibold mb-2">End Time *</label>
            <input type="time" required class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500" />
          </div>
        </div>

        <div>
          <label class="block text-gray-700 font-semibold mb-2">Your Name *</label>
          <input type="text" required class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500" />
        </div>

        <div>
          <label class="block text-gray-700 font-semibold mb-2">Email *</label>
          <input type="email" required class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-blue-500" />
        </div>

        <button type="submit" class="w-full bg-blue-500 text-white py-3 px-6 rounded-lg font-bold hover:bg-blue-600 transition-colors">
          Book Now
        </button>
      </form>
    </div>

    <!-- Bookings List -->
    <div>
      <h3 class="text-2xl font-bold text-gray-800 mb-4">Your Bookings</h3>
      <div class="space-y-3">
        <div class="border-l-4 border-blue-500 bg-gray-50 p-4 rounded-lg">
          <h4 class="font-bold text-gray-800">📅 2024-07-15 at 10:00</h4>
          <p class="text-sm text-gray-600 mt-1"><strong>Court:</strong> Court A</p>
          <p class="text-sm text-gray-600"><strong>Duration:</strong> 60 minutes</p>
          <span class="inline-block mt-2 bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-semibold">confirmed</span>
        </div>
        <div class="border-l-4 border-blue-500 bg-gray-50 p-4 rounded-lg">
          <h4 class="font-bold text-gray-800">📅 2024-07-20 at 14:00</h4>
          <p class="text-sm text-gray-600 mt-1"><strong>Court:</strong> Court C</p>
          <p class="text-sm text-gray-600"><strong>Duration:</strong> 90 minutes</p>
          <span class="inline-block mt-2 bg-green-100 text-green-700 px-3 py-1 rounded-full text-xs font-semibold">confirmed</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function handleBooking(e) {
    e.preventDefault();
    alert('Booking submitted! This is a demo.');
  }
</script>
