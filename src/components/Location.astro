---

<!-- Location Section -->
<section class="bg-white py-12 md:py-16 header-padding" style="padding-left: 100px; padding-right: 100px;">
  <div class="w-full">
    <!-- Location Section -->
    <div id="booking" class="mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-[#143315] mb-3">Where Are We Located?</h2>
      <p class="text-base md:text-lg text-[#143315]/80 mb-2">
        Your next great game is just around the corner
      </p>
      <p class="text-sm md:text-base text-[#143315] font-semibold mb-6 flex items-start gap-2">
        <svg class="h-5 w-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <span>Day-as Barangay Rd, Nangka Day-As, Cordova, 6017 Cebu</span>
      </p>
      
      <!-- Location Map -->
      <div class="mb-6">
        <div class="relative w-full h-[400px] md:h-[500px] rounded-lg overflow-hidden shadow-lg">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3926.087880980788!2d123.93715497451139!3d10.254495968604962!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x33a99a57d9ca1cb1%3A0xc04ea98ed8fc3c58!2sCasa%20Rugina!5e0!3m2!1sen!2sph!4v1782824609800!5m2!1sen!2sph"
            width="100%" 
            height="100%" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="strict-origin-when-cross-origin"
            class="w-full h-full"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
