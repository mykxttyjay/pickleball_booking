---
---

<!-- Hero Section -->
<section id="home" class="relative h-[calc(100vh-6.5rem)] md:h-[calc(100vh-6rem)] bg-cover bg-center flex items-center justify-center mt-[6.5rem] md:mt-24 overflow-hidden" style="background-image: url('/casaruginahome.jpg');">
  <!-- Enhanced overlay with gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/30 to-black/50"></div>
  
  <!-- Subtle animated pattern overlay -->
  <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,.1) 35px, rgba(255,255,255,.1) 70px);"></div>
  
  <div class="relative z-10 text-center px-4 max-w-7xl mx-auto">
    <!-- Tagline with enhanced styling -->
    <p class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl text-[#efe7dc] mb-4 whitespace-nowrap" style="font-family: 'Poppins', sans-serif; font-weight: 900; text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.8), 0 0 20px rgba(0, 0, 0, 0.6);">
      Your go-to spot for pickleball fun!
    </p>
    <p class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl text-white mb-12 md:mb-16 whitespace-nowrap" style="font-family: 'Poppins', sans-serif; font-weight: 700; text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.8), 0 0 20px rgba(0, 0, 0, 0.6);">
      Come play with us!
    </p>
    
    <!-- Enhanced CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-5 justify-center items-center">
      <a href="#booking" class="group relative inline-flex items-center justify-center bg-[#143315] text-white font-bold py-4 px-10 md:py-5 md:px-12 rounded-xl hover:bg-[#1a4a1f] transition-all duration-300 shadow-2xl hover:shadow-[#143315]/50 transform hover:-translate-y-2 text-base md:text-lg overflow-hidden">
        <span class="relative z-10">Book a Court</span>
        <div class="absolute inset-0 bg-gradient-to-r from-[#1a4a1f] to-[#143315] opacity-0 group-hover:opacity-100 transition-opacity"></div>
      </a>
      
      <a href="#open-play" class="group relative inline-flex items-center justify-center bg-[#efe7dc] text-[#143315] font-bold py-4 px-10 md:py-5 md:px-12 rounded-xl hover:bg-white transition-all duration-300 shadow-2xl hover:shadow-[#efe7dc]/50 transform hover:-translate-y-2 text-base md:text-lg border-2 border-[#efe7dc] hover:border-white overflow-hidden">
        <span class="relative z-10">Join Open Play</span>
        <div class="absolute inset-0 bg-white opacity-0 group-hover:opacity-100 transition-opacity"></div>
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fadeIn {
    animation: fadeIn 1s ease-out;
  }
</style>
