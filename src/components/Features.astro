---
---

<!-- Features Section -->
<section id="features" class="bg-white py-12 md:py-16 header-padding" style="padding-left: 100px; padding-right: 100px;">
  <div class="w-full">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-[#143315] mb-4" style="font-family: 'Poppins', sans-serif;">
        Your Ultimate Pickleball Destination
      </h2>
      <p class="text-base md:text-lg text-[#143315]/80">
        More than just courts—it's where memories are made
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10">
      
      <!-- Feature 1: 24/7 Access -->
      <div class="bg-[#efe7dc] rounded-xl p-6 md:p-8 text-center hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="inline-flex items-center justify-center w-16 h-16 md:w-20 md:h-20 bg-[#143315] rounded-full mb-4">
          <svg class="w-8 h-8 md:w-10 md:h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="text-xl md:text-2xl font-bold text-[#143315] mb-3">Open 24 Hours</h3>
        <p class="text-sm md:text-base text-[#143315]/70">
          Play anytime that fits your schedule. Our courts are accessible around the clock for your convenience.
        </p>
      </div>

      <!-- Feature 2: Affordable Rates -->
      <div class="bg-[#efe7dc] rounded-xl p-6 md:p-8 text-center hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="inline-flex items-center justify-center w-16 h-16 md:w-20 md:h-20 bg-[#143315] rounded-full mb-4">
          <svg class="w-8 h-8 md:w-10 md:h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="text-xl md:text-2xl font-bold text-[#143315] mb-3">Affordable Rates</h3>
        <p class="text-sm md:text-base text-[#143315]/70">
          Quality pickleball experience without breaking the bank. Competitive pricing for everyone to enjoy.
        </p>
      </div>

      <!-- Feature 3: All Skill Levels -->
      <div class="bg-[#efe7dc] rounded-xl p-6 md:p-8 text-center hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="inline-flex items-center justify-center w-16 h-16 md:w-20 md:h-20 bg-[#143315] rounded-full mb-4">
          <svg class="w-8 h-8 md:w-10 md:h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
          </svg>
        </div>
        <h3 class="text-xl md:text-2xl font-bold text-[#143315] mb-3">All Skill Levels Welcome</h3>
        <p class="text-sm md:text-base text-[#143315]/70">
          Whether you're a beginner or pro, our facility welcomes players of all levels to enjoy the game.
        </p>
      </div>

      <!-- Feature 4: Community -->
      <div class="bg-[#efe7dc] rounded-xl p-6 md:p-8 text-center hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="inline-flex items-center justify-center w-16 h-16 md:w-20 md:h-20 bg-[#143315] rounded-full mb-4">
          <svg class="w-8 h-8 md:w-10 md:h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <h3 class="text-xl md:text-2xl font-bold text-[#143315] mb-3">Vibrant Community</h3>
        <p class="text-sm md:text-base text-[#143315]/70">
          Join our friendly community of players for open play sessions and meet fellow pickleball enthusiasts.
        </p>
      </div>

    </div>
  </div>
</section>
