---
---

<!-- Footer -->
<footer class="bg-[#143315] text-white">
  <!-- Main Footer Content -->
  <div class="py-12 md:py-16 header-padding" style="padding-left: 100px; padding-right: 100px;">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      <!-- Contact Info -->
      <div>
        <h3 class="text-xl font-bold mb-4">Contact Us</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-2">
            <svg class="h-5 w-5 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span class="text-white/80">Day-as Barangay Rd, Nangka Day-As, Cordova, 6017 Cebu</span>
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <div class="text-white/80">
              <a href="tel:0966576931" class="hover:text-white">0966 576 931</a><br/>
              <a href="tel:09164601708" class="hover:text-white">0916 460 1708</a>
            </div>
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <a href="mailto:info@casarugina.com" class="text-white/80 hover:text-white">info@casarugina.com</a>
          </li>
        </ul>
      </div>

      <!-- Operating Hours -->
      <div>
        <h3 class="text-xl font-bold mb-4">Operating Hours</h3>
        <ul class="space-y-2 text-sm text-white/80">
          <li class="flex justify-between gap-4">
            <span>Monday - Friday:</span>
            <span class="font-semibold">6:00 AM - 10:00 PM</span>
          </li>
          <li class="flex justify-between gap-4">
            <span>Saturday:</span>
            <span class="font-semibold">6:00 AM - 11:00 PM</span>
          </li>
          <li class="flex justify-between gap-4">
            <span>Sunday:</span>
            <span class="font-semibold">6:00 AM - 11:00 PM</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="bg-[#efe7dc] py-6">
    <div class="header-padding" style="padding-left: 100px; padding-right: 100px;">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <!-- Logo -->
        <div class="flex items-center gap-3">
          <img src="/casaruginalogo.jpg" alt="Casa Rugina Logo" class="h-12 w-auto object-contain" />
          <div class="text-[#143315]">
            <h4 class="font-bold text-lg">Casa Rugina Pickleball Club</h4>
            <p class="text-xs uppercase tracking-wider">Play. Connect. Belong.</p>
          </div>
        </div>

        <!-- Social Media & Handle -->
        <div class="flex items-center gap-4">
          <a href="https://www.facebook.com/profile.php?id=61584996714040" target="_blank" rel="noopener" class="text-[#143315] hover:text-[#143315]/70 transition-colors">
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>

        <!-- Copyright -->
        <div class="text-[#143315]/60 text-sm">
          © 2024 Casa Rugina. All rights reserved.
        </div>
      </div>
    </div>
  </div>
</footer>
