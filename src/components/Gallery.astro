            <img src="/openplay7.jpg" alt="Open Play Session 7" class="h-64 md:h-80 w-auto object-cover rounded-lg shadow-xl" />
          </div>
          <div class="marquee-item">
            <img src="/openplay8.jpg" alt="Open Play Session 8" class="h-64 md:h-80 w-auto object-cover rounded-lg shadow-xl" />
          </div>
          <div class="marquee-item">
            <img src="/openplay9.jpg" alt="Open Play Session 9" class="h-64 md:h-80 w-auto object-cover rounded-lg shadow-xl" />
          </div>
          <div class="marquee-item">
            <img src="/openplay10.jpg" alt="Open Play Session 10" class="h-64 md:h-80 w-auto object-cover rounded-lg shadow-xl" />
          </div>
          <div class="marquee-item">
            <img src="/openplay11.jpg" alt="Open Play Session 11" class="h-64 md:h-80 w-auto object-cover rounded-lg shadow-xl" />
          </div>
          <div class="marquee-item">
            <img src="/openplay12.jpg" alt="Open Play Session 12" class="h-64 md:h-80 w-auto object-cover rounded-lg shadow-xl" />
          </div>
          
          <!-- Duplicate set for seamless loop -->
          <div class="marquee-item">
            <img src="/openplay1.jpg" alt="Open Play Session 1" class="h-64 md:h-80 w-auto object-cover rounded-lg shadow-xl" />
          </div>
