---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Book a Court - Casa Rugina Pickleball Club">
  <style>
    @media (min-width: 768px) {
      .header-padding {
        padding-left: 100px !important;
        padding-right: 100px !important;
      }
    }
    @media (min-width: 1024px) {
      .header-padding {
        padding-left: 200px !important;
        padding-right: 200px !important;
      }
    }
    @media (min-width: 1280px) {
      .header-padding {
        padding-left: 300px !important;
        padding-right: 300px !important;
      }
    }
    @media (min-width: 1536px) {
      .header-padding {
        padding-left: 400px !important;
        padding-right: 400px !important;
      }
    }
    @media (min-width: 1920px) {
      .header-padding {
        padding-left: 500px !important;
        padding-right: 500px !important;
      }
    }
  </style>

  <Header />

  <!-- Booking Hero Section -->
  <section class="bg-[#143315] text-white py-20 md:py-24 mt-[6.5rem] md:mt-24">
    <div class="header-padding" style="padding-left: 100px; padding-right: 100px;">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4" style="font-family: 'Poppins', sans-serif;">
          Book Your Court
        </h1>
        <p class="text-lg md:text-xl text-white/90">
          Reserve your spot and get ready to play!
        </p>
      </div>
    </div>
  </section>

  <!-- Booking Content Section -->
  <section class="bg-white py-12 md:py-16 header-padding" style="padding-left: 100px; padding-right: 100px;">
    <div class="w-full max-w-4xl mx-auto">
      
      <!-- Contact Information -->
      <div class="bg-[#efe7dc] rounded-xl p-8 md:p-10 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#143315] mb-6" style="font-family: 'Poppins', sans-serif;">
          How to Book
        </h2>
        <p class="text-base md:text-lg text-[#143315]/80 mb-6">
          To reserve a court, please contact us directly through any of the following methods:
        </p>
        
        <div class="space-y-4">
          <!-- Phone -->
          <div class="flex items-center gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-[#143315] rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm text-[#143315]/60 mb-1">Call Us</p>
              <div class="flex gap-2">
                <a href="tel:0966576931" class="text-lg font-semibold text-[#143315] hover:text-[#143315]/70 transition-colors">0966 576 931</a>
                <span class="text-[#143315]/40">/</span>
                <a href="tel:09164601708" class="text-lg font-semibold text-[#143315] hover:text-[#143315]/70 transition-colors">0916 460 1708</a>
              </div>
            </div>
          </div>

          <!-- Facebook -->
          <div class="flex items-center gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-[#143315] rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm text-[#143315]/60 mb-1">Message Us on Facebook</p>
              <a href="https://www.facebook.com/profile.php?id=61584996714040" target="_blank" rel="noopener" class="text-lg font-semibold text-[#143315] hover:text-[#143315]/70 transition-colors">
                Casa Rugina Pickleball Club
              </a>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-center gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-[#143315] rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm text-[#143315]/60 mb-1">Email Us</p>
              <a href="mailto:info@casarugina.com" class="text-lg font-semibold text-[#143315] hover:text-[#143315]/70 transition-colors">
                info@casarugina.com
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Rates Information -->
      <div class="bg-[#efe7dc] rounded-xl p-8 md:p-10 mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-[#143315] mb-6" style="font-family: 'Poppins', sans-serif;">
          Court Rates
        </h2>
        <div class="space-y-4">
          <div class="flex justify-between items-center py-3 border-b border-[#143315]/20">
            <span class="text-lg text-[#143315]">Hourly Rate</span>
            <span class="text-xl font-bold text-[#143315]">Contact for pricing</span>
          </div>
          <p class="text-sm text-[#143315]/70 mt-4">
            * Rates may vary depending on time and day. Please contact us for current pricing and availability.
          </p>
        </div>
      </div>

      <!-- What to Bring -->
      <div class="bg-[#efe7dc] rounded-xl p-8 md:p-10">
        <h2 class="text-2xl md:text-3xl font-bold text-[#143315] mb-6" style="font-family: 'Poppins', sans-serif;">
          What to Bring
        </h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-[#143315] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-base text-[#143315]/80">Your own pickleball paddle and balls (or rent on-site)</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-[#143315] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-base text-[#143315]/80">Comfortable athletic shoes with non-marking soles</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-[#143315] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-base text-[#143315]/80">Water bottle to stay hydrated</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-[#143315] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
            <span class="text-base text-[#143315]/80">A positive attitude and ready to have fun!</span>
          </li>
        </ul>
      </div>

      <!-- Back to Home Button -->
      <div class="text-center mt-10">
        <a href="/" class="inline-block bg-[#143315] text-white font-bold py-3 px-8 rounded-lg hover:bg-[#efe7dc] hover:text-[#143315] transition-all shadow-lg text-base md:text-lg">
          Back to Home
        </a>
      </div>

    </div>
  </section>

  <Footer />
</Layout>
