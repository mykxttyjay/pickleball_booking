---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Casa Rugina Pickleball Club</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: 'Poppins', sans-serif;
        background-color: #efe7dc;
      }
      @media (min-width: 1024px) {
        .header-padding {
          padding-left: 100px !important;
          padding-right: 100px !important;
        }
      }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="bg-white shadow-lg fixed w-full top-0 z-50">
      <div class="w-full py-4 md:py-6 flex items-center justify-between px-4 md:px-8 lg:header-padding">
        <div class="flex items-center gap-4 md:gap-8">
          <img src="/casaruginalogo.jpg" alt="Casa Rugina Logo" class="h-10 md:h-16 w-auto object-contain" />
          <nav class="hidden md:flex gap-6 lg:gap-8">
            <a href="#home" class="text-[#143315] text-sm lg:text-base font-medium hover:text-[#143315]/70 transition-colors border-b-2 border-transparent hover:border-[#143315] pb-1">Home</a>
            <a href="#gallery" class="text-[#143315] text-sm lg:text-base font-medium hover:text-[#143315]/70 transition-colors border-b-2 border-transparent hover:border-[#143315] pb-1">Gallery</a>
            <a href="#booking" class="text-[#143315] text-sm lg:text-base font-medium hover:text-[#143315]/70 transition-colors border-b-2 border-transparent hover:border-[#143315] pb-1">Book</a>
            <a href="#open-play" class="text-[#143315] text-sm lg:text-base font-medium hover:text-[#143315]/70 transition-colors border-b-2 border-transparent hover:border-[#143315] pb-1">Open Play</a>
          </nav>
        </div>
        <div class="hidden lg:block">
          <a href="tel:0966576931" class="text-[#143315] font-semibold flex items-center gap-2 text-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <span>0966 576 931 / 0916 460 1708</span>
          </a>
        </div>
        <!-- Mobile menu button -->
        <button class="md:hidden text-[#143315]" id="mobile-menu-btn" aria-label="Toggle menu">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
      <!-- Mobile menu -->
      <div class="hidden md:hidden bg-white border-t" id="mobile-menu">
        <nav class="flex flex-col px-4 py-4 space-y-2">
          <a href="#home" class="mobile-link text-[#143315] font-medium py-2 hover:bg-[#efe7dc] px-2 rounded">Home</a>
          <a href="#gallery" class="mobile-link text-[#143315] font-medium py-2 hover:bg-[#efe7dc] px-2 rounded">Gallery</a>
          <a href="#booking" class="mobile-link text-[#143315] font-medium py-2 hover:bg-[#efe7dc] px-2 rounded">Book</a>
          <a href="#open-play" class="mobile-link text-[#143315] font-medium py-2 hover:bg-[#efe7dc] px-2 rounded">Open Play</a>
          <a href="tel:0966576931" class="text-[#143315] font-medium py-2 hover:bg-[#efe7dc] px-2 rounded flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            Call us
          </a>
        </nav>
      </div>
    </header>

    <!-- Hero Section -->
    <section id="home" class="relative h-screen bg-cover bg-center flex items-center justify-center mt-14 md:mt-20" style="background-image: url('/casaruginacover.jpg');">
      <div class="absolute inset-0 bg-black opacity-50"></div>
      <div class="relative z-10 text-center px-4">
        <h1 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-4 uppercase tracking-wider" style="text-shadow: 2px 2px 8px rgba(0,0,0,0.7);">
          Casa Rugina Pickleball
        </h1>
        <p class="text-lg sm:text-xl md:text-3xl lg:text-4xl text-[#efe7dc] font-light italic" style="text-shadow: 2px 2px 6px rgba(0,0,0,0.7);">
          "Play. Connect. Belong."
        </p>
      </div>
    </section>

    <!-- Gallery Section -->
    <section id="gallery" class="bg-[#efe7dc] py-12 md:py-16 px-4 md:px-8">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-8 md:mb-12">
          <p class="text-2xl md:text-3xl lg:text-4xl text-[#143315] font-semibold mb-6 italic">
            "Where Every Game Feels Like Home"
          </p>
          <a href="#booking" class="inline-block bg-[#143315] text-white font-bold py-3 px-8 rounded-lg hover:bg-[#143315]/90 transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-1">
            BOOK NOW
          </a>
        </div>
        
        <!-- Gallery Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 mt-12">
          <div class="relative overflow-hidden rounded-lg shadow-lg group cursor-pointer h-64 md:h-80">
            <img src="/court1.jpg" alt="Court 1" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" />
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <span class="text-white text-xl font-semibold">Court A</span>
            </div>
          </div>
          
          <div class="relative overflow-hidden rounded-lg shadow-lg group cursor-pointer h-64 md:h-80">
            <img src="/court2.jpg" alt="Court 2" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" />
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <span class="text-white text-xl font-semibold">Court B</span>
            </div>
          </div>
          
          <div class="relative overflow-hidden rounded-lg shadow-lg group cursor-pointer h-64 md:h-80">
            <img src="/court3.jpg" alt="Court 3" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" />
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <span class="text-white text-xl font-semibold">Court C</span>
            </div>
          </div>
          
          <div class="relative overflow-hidden rounded-lg shadow-lg group cursor-pointer h-64 md:h-80">
            <img src="/court4.jpg" alt="Court 4" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" />
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <span class="text-white text-xl font-semibold">Facilities</span>
            </div>
          </div>
          
          <div class="relative overflow-hidden rounded-lg shadow-lg group cursor-pointer h-64 md:h-80">
            <img src="/court5.jpg" alt="Court 5" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" />
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <span class="text-white text-xl font-semibold">Lounge Area</span>
            </div>
          </div>
          
          <div class="relative overflow-hidden rounded-lg shadow-lg group cursor-pointer h-64 md:h-80">
            <img src="/court6.jpg" alt="Court 6" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-110" />
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
              <span class="text-white text-xl font-semibold">Night View</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Booking & Open Play Sections -->
    <div class="bg-[#efe7dc] py-8 md:py-12 px-4 md:px-8">
      <div class="max-w-7xl mx-auto">
        <!-- Tab Navigation -->
        <div class="flex flex-wrap gap-2 mb-6 md:mb-8 bg-white p-3 md:p-4 rounded-lg shadow-lg justify-center">
          <button class="tab-link flex-1 min-w-[120px] sm:flex-none py-2 md:py-3 px-4 md:px-6 rounded-lg font-bold transition-all bg-[#143315] text-white text-sm md:text-base" data-tab="booking">Book Court</button>
          <button class="tab-link flex-1 min-w-[120px] sm:flex-none py-2 md:py-3 px-4 md:px-6 rounded-lg font-bold transition-all bg-gray-100 text-gray-700 hover:bg-gray-200 text-sm md:text-base" data-tab="open-play">Open Play</button>
        </div>

        <!-- Booking Section -->
        <div id="booking" class="tab-section bg-white rounded-lg shadow-xl p-4 md:p-8 mb-8">
          <h2 class="text-2xl md:text-3xl font-bold text-[#143315] mb-4 md:mb-6 pb-4 border-b-4 border-[#143315]">Book a Court</h2>
          <p class="text-[#143315]">Booking form coming soon...</p>
        </div>

        <!-- Open Play Section -->
        <div id="open-play" class="tab-section bg-white rounded-lg shadow-xl p-4 md:p-8 hidden">
          <h2 class="text-2xl md:text-3xl font-bold text-[#143315] mb-4 md:mb-6 pb-4 border-b-4 border-[#143315]">Open Play Sessions</h2>
          <p class="text-[#143315]">Open play sessions coming soon...</p>
        </div>
      </div>
    </div>

    <script>
      // Mobile menu toggle
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      
      menuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });

      // Close mobile menu when clicking a link
      document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
        });
      });

      // Tab switching
      document.querySelectorAll('.tab-link').forEach(button => {
        button.addEventListener('click', () => {
          const tabName = button.getAttribute('data-tab');
          if (!tabName) return;
          
          document.querySelectorAll('.tab-link').forEach(b => {
            b.classList.remove('bg-[#143315]', 'text-white');
            b.classList.add('bg-gray-100', 'text-gray-700');
          });
          document.querySelectorAll('.tab-section').forEach(s => s.classList.add('hidden'));
          
          button.classList.remove('bg-gray-100', 'text-gray-700');
          button.classList.add('bg-[#143315]', 'text-white');
          
          const targetElement = document.getElementById(tabName);
          if (targetElement) {
            targetElement.classList.remove('hidden');
          }
        });
      });

      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({ behavior: 'smooth' });
          }
        });
      });
    </script>
</body>
</html>
