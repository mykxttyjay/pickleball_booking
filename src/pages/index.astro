---
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Casa Rugina Pickleball Club</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: 'Poppins', sans-serif;
        background-color: #efe7dc;
      }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="bg-white shadow-lg">
      <div class="max-w-6xl mx-auto px-6 md:px-8 py-4 flex items-center justify-between">
        <div class="flex items-center">
          <img src="/casaruginalogo.jpg" alt="Casarugina Logo" class="h-16 w-auto object-contain" />
        </div>
        <nav class="hidden md:flex gap-8">
          <a href="#home" class="text-[#143315] font-semibold hover:opacity-70">Home</a>
          <a href="#courts" class="text-[#143315] font-semibold hover:opacity-70">Courts</a>
          <a href="#booking" class="text-[#143315] font-semibold hover:opacity-70">Book</a>
          <a href="#open-play" class="text-[#143315] font-semibold hover:opacity-70">Open Play</a>
        </nav>
      </div>
    </header>

    <!-- Hero Section -->
    <section id="home" class="relative h-screen bg-cover bg-center flex items-center justify-center" style="background-image: url('https://images.unsplash.com/photo-1554224311-beee415c15cb?w=1200&h=600&fit=crop');">
      <div class="absolute inset-0 bg-black opacity-40"></div>
      <div class="relative z-10 text-center">
        <h1 class="text-6xl md:text-7xl font-bold text-white mb-6" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">Play</h1>
        <h2 class="text-5xl md:text-6xl font-bold text-white mb-6" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">Connect</h2>
        <h3 class="text-5xl md:text-6xl font-bold text-white" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">Belong</h3>
      </div>
    </section>

    <!-- Main Content -->
    <div class="bg-[#efe7dc] py-8 px-6 md:px-8">
      <div class="max-w-6xl mx-auto">
        <!-- Navigation Tabs -->
        <div class="flex gap-2 mb-8 bg-white p-4 rounded-lg shadow-lg flex-wrap justify-center">
          <button class="tab-link py-3 px-6 rounded-lg font-bold transition-all bg-[#143315] text-white" data-tab="courts">Courts</button>
          <button class="tab-link py-3 px-6 rounded-lg font-bold transition-all bg-gray-100 text-gray-700 hover:bg-gray-200" data-tab="booking">Book Court</button>
          <button class="tab-link py-3 px-6 rounded-lg font-bold transition-all bg-gray-100 text-gray-700 hover:bg-gray-200" data-tab="open-play">Open Play</button>
        </div>

        <!-- Courts Section -->
        <div id="courts" class="tab-section bg-white rounded-lg shadow-xl p-8 mb-8">
          <h2 class="text-3xl font-bold text-[#143315] mb-6 pb-4 border-b-4 border-[#143315]">Available Courts</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
            <div class="border-2 border-[#143315] rounded-lg p-6 bg-[#efe7dc] hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-bold text-[#143315] mb-3">Court A</h3>
              <div class="space-y-2 text-[#143315]">
                <p><strong>📍 Location:</strong> Downtown Park</p>
                <p><strong>🏐 Surface:</strong> Hard Court</p>
                <p><strong>💡 Lights:</strong> ✓ Yes</p>
              </div>
            </div>
            <div class="border-2 border-[#143315] rounded-lg p-6 bg-[#efe7dc] hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-bold text-[#143315] mb-3">Court B</h3>
              <div class="space-y-2 text-[#143315]">
                <p><strong>📍 Location:</strong> Central Recreation</p>
                <p><strong>🏐 Surface:</strong> Clay</p>
                <p><strong>💡 Lights:</strong> ✗ No</p>
              </div>
            </div>
            <div class="border-2 border-[#143315] rounded-lg p-6 bg-[#efe7dc] hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-bold text-[#143315] mb-3">Court C</h3>
              <div class="space-y-2 text-[#143315]">
                <p><strong>📍 Location:</strong> Riverside Complex</p>
                <p><strong>🏐 Surface:</strong> Hard Court</p>
                <p><strong>💡 Lights:</strong> ✓ Yes</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Booking Section -->
        <div id="booking" class="tab-section bg-white rounded-lg shadow-xl p-8 mb-8 hidden">
          <h2 class="text-3xl font-bold text-[#143315] mb-6 pb-4 border-b-4 border-[#143315]">Book a Court</h2>
          <p class="text-[#143315]">Booking form coming soon...</p>
        </div>

        <!-- Open Play Section -->
        <div id="open-play" class="tab-section bg-white rounded-lg shadow-xl p-8 hidden">
          <h2 class="text-3xl font-bold text-[#143315] mb-6 pb-4 border-b-4 border-[#143315]">Open Play Sessions</h2>
          <p class="text-[#143315]">Open play sessions coming soon...</p>
        </div>
      </div>
    </div>

    <script>
      // Tab switching
      document.querySelectorAll('.tab-link').forEach(button => {
        button.addEventListener('click', () => {
          const tabName = button.getAttribute('data-tab');
          if (!tabName) return;
          
          // Remove active from all tabs and buttons
          document.querySelectorAll('.tab-link').forEach(b => {
            b.classList.remove('bg-[#143315]', 'text-white');
            b.classList.add('bg-gray-100', 'text-gray-700');
          });
          document.querySelectorAll('.tab-section').forEach(s => s.classList.add('hidden'));
          
          // Add active to clicked button and corresponding section
          button.classList.remove('bg-gray-100', 'text-gray-700');
          button.classList.add('bg-[#143315]', 'text-white');
          
          const targetElement = document.getElementById(tabName);
          if (targetElement) {
            targetElement.classList.remove('hidden');
          }
        });
      });
    </script>
</body>
</html>
