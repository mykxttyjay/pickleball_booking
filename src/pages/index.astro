---
import Layout from '../layouts/Layout.astro';
import Courts from '../components/Courts.astro';
import Booking from '../components/Booking.astro';
import OpenPlay from '../components/OpenPlay.astro';
---

<Layout title="Pickleball Court Booking System">
  <div class="min-h-screen bg-gradient-to-br from-purple-500 to-pink-500 py-8 px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-5xl font-bold text-white mb-2">🎾 Pickleball Court Booking</h1>
        <p class="text-xl text-white/90">Book courts and join open play sessions</p>
      </div>

      <!-- Navigation Tabs -->
      <div class="flex gap-2 mb-8 bg-white p-4 rounded-lg shadow-lg flex-wrap justify-center">
        <a href="#courts" class="tab-link active py-3 px-6 rounded-lg font-bold transition-all bg-blue-500 text-white">Courts</a>
        <a href="#booking" class="tab-link py-3 px-6 rounded-lg font-bold transition-all bg-gray-100 text-gray-700 hover:bg-gray-200">Book Court</a>
        <a href="#open-play" class="tab-link py-3 px-6 rounded-lg font-bold transition-all bg-gray-100 text-gray-700 hover:bg-gray-200">Open Play</a>
      </div>

      <!-- Components -->
      <Courts />
      <Booking />
      <OpenPlay />
    </div>
  </div>

  <script>
    // Tab switching
    document.querySelectorAll('.tab-link').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        
        // Remove active from all tabs and links
        document.querySelectorAll('.tab-link').forEach(l => {
          l.classList.remove('active', 'bg-blue-500', 'text-white');
          l.classList.add('bg-gray-100', 'text-gray-700');
        });
        document.querySelectorAll('.tab-section').forEach(s => s.classList.add('hidden'));
        
        // Add active to clicked link and corresponding section
        link.classList.add('active', 'bg-blue-500', 'text-white');
        link.classList.remove('bg-gray-100', 'text-gray-700');
        
        const targetId = link.getAttribute('href').substring(1);
        document.getElementById(targetId).classList.remove('hidden');
      });
    });
  </script>
</Layout>
