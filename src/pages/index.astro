---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Casa Rugina Pickleball Club</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: 'Poppins', sans-serif;
        background-color: #efe7dc;
      }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="bg-white shadow-lg fixed w-full top-0 z-50">
      <div class="w-full py-6 flex items-center justify-between" style="padding-left: 100px; padding-right: 100px;">
        <div class="flex items-center gap-8">
          <img src="/casaruginalogo.jpg" alt="Casa Rugina Logo" class="h-16 w-auto object-contain" />
          <nav class="hidden md:flex gap-8">
            <a href="#home" class="text-[#143315] font-medium hover:text-[#143315]/70 transition-colors border-b-2 border-transparent hover:border-[#143315] pb-1">Home</a>
            <a href="#courts" class="text-[#143315] font-medium hover:text-[#143315]/70 transition-colors border-b-2 border-transparent hover:border-[#143315] pb-1">Courts</a>
            <a href="#booking" class="text-[#143315] font-medium hover:text-[#143315]/70 transition-colors border-b-2 border-transparent hover:border-[#143315] pb-1">Book</a>
            <a href="#open-play" class="text-[#143315] font-medium hover:text-[#143315]/70 transition-colors border-b-2 border-transparent hover:border-[#143315] pb-1">Open Play</a>
          </nav>
        </div>
        <div class="hidden md:block">
          <a href="tel:0966576931" class="text-[#143315] font-semibold flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <span>Call us 0966 576 931 / 0916 460 1708</span>
          </a>
        </div>
      </div>
    </header>

    <!-- Hero Section -->
    <section id="home" class="relative h-screen bg-cover bg-center flex items-center justify-center mt-20" style="background-image: url('/casaruginacover.jpg');">
      <div class="absolute inset-0 bg-black opacity-50"></div>
      <div class="relative z-10 text-center px-4">
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-4 uppercase tracking-wider" style="text-shadow: 2px 2px 8px rgba(0,0,0,0.7);">
          Casa Rugina Pickleball Club
        </h1>
        <p class="text-2xl md:text-4xl text-[#efe7dc] font-light italic mb-8" style="text-shadow: 2px 2px 6px rgba(0,0,0,0.7);">
          "Play. Connect. Belong."
        </p>
      </div>
    </section>

    <!-- Main Content -->
    <div class="bg-[#efe7dc] py-12 px-6 md:px-8">
      <div class="max-w-7xl mx-auto">
        <!-- Navigation Tabs -->
        <div class="flex gap-2 mb-8 bg-white p-4 rounded-lg shadow-lg flex-wrap justify-center">
          <button class="tab-link py-3 px-6 rounded-lg font-bold transition-all bg-[#143315] text-white" data-tab="courts">Courts</button>
          <button class="tab-link py-3 px-6 rounded-lg font-bold transition-all bg-gray-100 text-gray-700 hover:bg-gray-200" data-tab="booking">Book Court</button>
          <button class="tab-link py-3 px-6 rounded-lg font-bold transition-all bg-gray-100 text-gray-700 hover:bg-gray-200" data-tab="open-play">Open Play</button>
        </div>

        <!-- Courts Section -->
        <div id="courts" class="tab-section bg-white rounded-lg shadow-xl p-8 mb-8">
          <h2 class="text-3xl font-bold text-[#143315] mb-6 pb-4 border-b-4 border-[#143315]">Available Courts</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
            <div class="border-2 border-[#143315] rounded-lg p-6 bg-[#efe7dc] hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-bold text-[#143315] mb-3">Court A</h3>
              <div class="space-y-2 text-[#143315]">
                <p><strong>📍 Location:</strong> Downtown Park</p>
                <p><strong>🏐 Surface:</strong> Hard Court</p>
                <p><strong>💡 Lights:</strong> ✓ Yes</p>
              </div>
            </div>
            <div class="border-2 border-[#143315] rounded-lg p-6 bg-[#efe7dc] hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-bold text-[#143315] mb-3">Court B</h3>
              <div class="space-y-2 text-[#143315]">
                <p><strong>📍 Location:</strong> Central Recreation</p>
                <p><strong>🏐 Surface:</strong> Clay</p>
                <p><strong>💡 Lights:</strong> ✗ No</p>
              </div>
            </div>
            <div class="border-2 border-[#143315] rounded-lg p-6 bg-[#efe7dc] hover:shadow-lg transition-shadow">
              <h3 class="text-xl font-bold text-[#143315] mb-3">Court C</h3>
              <div class="space-y-2 text-[#143315]">
                <p><strong>📍 Location:</strong> Riverside Complex</p>
                <p><strong>🏐 Surface:</strong> Hard Court</p>
                <p><strong>💡 Lights:</strong> ✓ Yes</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Booking Section -->
        <div id="booking" class="tab-section bg-white rounded-lg shadow-xl p-8 mb-8 hidden">
          <h2 class="text-3xl font-bold text-[#143315] mb-6 pb-4 border-b-4 border-[#143315]">Book a Court</h2>
          <p class="text-[#143315]">Booking form coming soon...</p>
        </div>

        <!-- Open Play Section -->
        <div id="open-play" class="tab-section bg-white rounded-lg shadow-xl p-8 hidden">
          <h2 class="text-3xl font-bold text-[#143315] mb-6 pb-4 border-b-4 border-[#143315]">Open Play Sessions</h2>
          <p class="text-[#143315]">Open play sessions coming soon...</p>
        </div>
      </div>
    </div>

    <script>
      // Tab switching
      document.querySelectorAll('.tab-link').forEach(button => {
        button.addEventListener('click', () => {
          const tabName = button.getAttribute('data-tab');
          if (!tabName) return;
          
          // Remove active from all tabs and buttons
          document.querySelectorAll('.tab-link').forEach(b => {
            b.classList.remove('bg-[#143315]', 'text-white');
            b.classList.add('bg-gray-100', 'text-gray-700');
          });
          document.querySelectorAll('.tab-section').forEach(s => s.classList.add('hidden'));
          
          // Add active to clicked button and corresponding section
          button.classList.remove('bg-gray-100', 'text-gray-700');
          button.classList.add('bg-[#143315]', 'text-white');
          
          const targetElement = document.getElementById(tabName);
          if (targetElement) {
            targetElement.classList.remove('hidden');
          }
        });
      });

      // Smooth scroll for navigation
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({ behavior: 'smooth' });
          }
        });
      });
    </script>
</body>
</html>
